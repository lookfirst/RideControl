{
	"compilerOptions": {
		"target": "esnext",
		"jsx": "react-jsx",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"skipLibCheck": true,
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"noEmit": true,
		"strict": true,
		"types": ["@types/web-bluetooth", "bun", "vite/client"]
	},
	"include": ["src", "tests"]
}
